# Источник данных для фронта (CLAUDE.md §3).
# chain → ChainDataProvider (реальный кошелёк devnet + индексер, Фаза 3) — основной
# api   → ApiDataProvider   (бэкенд по HTTP, dev-вход по адресу без кошелька)
# mock  → MockDataProvider  (in-browser, dev-вход по адресу)
NEXT_PUBLIC_DATA_SOURCE=chain

# Инъекция ошибок в мок для прогона error-стейтов (mock-data.md §3). off по умолчанию.
NEXT_PUBLIC_MOCK_FAIL=off

# БЕЗОПАСНОСТЬ (ADR 0008, C1): СЕРВЕРНЫЙ флаг chain-режима (НЕ NEXT_PUBLIC — недоступен клиенту, не
# подделать из браузера). on → оффчейн-симуляция `createDonation` по RPC ЗАПРЕЩЕНА (отдаёт CHAIN_MODE);
# репутацию начисляет только ingestSignature по ончейн-подтверждённому донату. Иначе любой вошедший
# кошелёк мог бы бесплатно наколдовать донат+репутацию мимо цепочки.
# Fail-safe: в production закрыто ПО УМОЛЧАНИЮ. Для редкого prod-деплоя api/mock-режима — CHAIN_MODE=off.
# В chain-проде на mainnet оставляй on (или не задавай — по умолчанию закрыто).
CHAIN_MODE=on

# SIWS-домен в подписываемом сообщении (ADR 0011 / M1): пользователь видит, куда входит, и подпись не
# переносится меж-app. Серверная переменная (не NEXT_PUBLIC). На проде задай реальный домен приложения.
# APP_DOMAIN=standing.app

# Фаза 3. В DEV опциональны — есть devnet-дефолты (Circle devnet USDC + сген. трежери, секрет в
# .treasury-devnet.json). Пусто в dev → createDonation бросит NOT_CONFIGURED.
# БЕЗОПАСНОСТЬ (ADR 0009 / аудит C2): в PRODUCTION devnet-дефолты ЗАПРЕЩЕНЫ, переменные ОБЯЗАТЕЛЬНЫ —
# иначе сервер не стартует (instrumentation) и денежный путь fail-closed. Devnet-трежери на mainnet =
# слать 3% на адрес, чей ключ в плейнтексте. На mainnet: mainnet-USDC-mint + СВЕЖИЙ (мульти-сиг/HSM) трежери.
# NEXT_PUBLIC_DEVNET_USDC_MINT=
# NEXT_PUBLIC_TREASURY_OWNER=

# Адрес оператора платформы (/ops: баны/саспенды, карантин, инцидент-лог; репутацию НЕ редактирует, CR-1).
# В DEV по умолчанию = трежери.
# БЕЗОПАСНОСТЬ: оператор key-gated (ADR 0006). В PRODUCTION НЕ наследует трежери, ОБЯЗАН быть задан И
# отличаться от трежери (одноключевой риск) — иначе fail-closed (сервер не стартует). Желательно мульти-сиг.
# NEXT_PUBLIC_OPERATOR_ADDRESS=

# ВНИМАНИЕ: личность запроса берётся ТОЛЬКО из проверенного SIWS-токена. Dev-вход по адресу без подписи
# (тулбар/`/connect` под mock/api) и `__reset` работают исключительно при NODE_ENV != production.
# Прод-сборка (`next build && next start`) выставляет NODE_ENV=production автоматически.

# Модерация (опц.): OpenAI omni-moderation — бесплатный мультиязычный классификатор текста донатов.
# СЕРВЕРНАЯ переменная (НЕ NEXT_PUBLIC — ключ не должен попасть в клиентский bundle). Задан → авто-слой
# модерации = OpenAI (авто-карантин только sexual/minors по умолчанию, маппинг в lib/data/moderation.ts);
# не задан → локальный словарь явных маркеров. Endpoint бесплатный, ключ — platform.openai.com.
# OPENAI_API_KEY=

# WalletConnect (опц.): подключение мобильных/прочих кошельков по QR. PUBLIC projectId с cloud.reown.com
# (бесплатно). Не задан → WalletConnect просто не показывается в модалке (Phantom/Solflare/Coinbase/Trust/
# Ledger и авто-детект Standard-кошельков работают и без него).
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
