# Источник данных для фронта (CLAUDE.md §3). Фаза 1 = mock.
# mock  → MockDataProvider (данные в памяти, симуляция) — текущая фаза
# api   → ApiDataProvider   (бэкенд, Фаза 2)
# chain → ChainDataProvider (кошелёк + индексер, Фаза 3)
NEXT_PUBLIC_DATA_SOURCE=mock

# Сид мока для детерминированных фикстур/скриншотов (Фаза 1).
NEXT_PUBLIC_MOCK_SEED=standing-v0.1

# Инъекция ошибок в мок для прогона error-стейтов (mock-data.md §3). off по умолчанию.
NEXT_PUBLIC_MOCK_FAIL=off
